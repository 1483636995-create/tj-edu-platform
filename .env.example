NODE_ENV=development

# API
API_PORT=4000
WEB_PORT=3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tj_edu_platform

# Redis
REDIS_URL=redis://localhost:6379

# Object storage, replace with Tencent COS / Aliyun OSS / S3-compatible values later.
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_BUCKET=tj-edu-platform
STORAGE_ACCESS_KEY=local
STORAGE_SECRET_KEY=local_secret
