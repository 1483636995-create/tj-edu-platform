NODE_ENV=development

# API
API_PORT=4000
WEB_PORT=3000
WEB_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Authentication
JWT_SECRET=local-only-jwt-secret-change-before-production-2026
JWT_EXPIRES_IN_SECONDS=28800
SEED_ADMIN_EMAIL=admin@tj-edu.local
SEED_ADMIN_PASSWORD=ChangeMe123!

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tj_edu_platform

# Redis
REDIS_URL=redis://localhost:6379

# Object storage, replace with Tencent COS / Aliyun OSS / S3-compatible values later.
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_BUCKET=tj-edu-platform
STORAGE_ACCESS_KEY=local
STORAGE_SECRET_KEY=local_secret
